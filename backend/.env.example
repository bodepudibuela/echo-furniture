# ============================================================
# Echo-Furniture Environment Variables
# ============================================================
# Copy this file to .env and fill in your values

# Server
PORT=5000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=echo_furniture

# JWT
JWT_SECRET=echo_furniture_super_secret_key_change_in_production_2024
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=echo_furniture_refresh_secret_change_in_production_2024
JWT_REFRESH_EXPIRES_IN=30d

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Email (optional, for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=noreply@echofurniture.com

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./public/uploads

# Payment Gateway (Mock)
PAYMENT_GATEWAY_KEY=mock_payment_key_echo_furniture
PAYMENT_GATEWAY_SECRET=mock_payment_secret

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100
